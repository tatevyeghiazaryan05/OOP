int add(int a, int b) {
    int result = a + b;
    return result;
}

int main() {
    int x = 10;
    int y = 20;
    int count = 0;

    if (x < y) {
        x = x + 1;
    }

    while (count < 5) {
        count = count + 1;
    }

    do {
        x = x - 1;
    } while (x > 0);

    return 0;
}
